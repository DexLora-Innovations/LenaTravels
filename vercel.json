{
  "version": 2,
  "builds": [
    { "src": "api/ssr.js", "use": "@vercel/node" },
    { "src": "dist/client/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/dist/client/assets/$1" },
    { "src": "/favicon.ico", "dest": "/dist/client/favicon.ico" },
    { "src": "/favicon.svg", "dest": "/dist/client/favicon.svg" },
    { "src": "^/(.*)$", "dest": "/api/ssr.js" }
  ],
  "functions": {
    "api/ssr.js": {
      "includeFiles": "dist/server/**"
    }
  }
}
