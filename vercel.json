{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "builds": [
    {
      "src": "api/ssr.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/server/**", "dist/client/**"]
      }
    },
    {
      "src": "dist/client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*\\.(js|css|woff2?|ttf|otf|eot|ico|svg|png|jpg|jpeg|webp|gif|avif))",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "/favicon\\.ico",
      "dest": "/dist/client/favicon.ico"
    },
    {
      "src": "/favicon\\.svg",
      "dest": "/dist/client/favicon.svg"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/ssr.js"
    }
  ]
}
